    "# ── Section: Autoencoder Embeddings for Clustering ──────────────────────────\n",
    "import tensorflow as tf\n",
    "from tensorflow import keras\n",
    "from tensorflow.keras import layers\n",
    "from sklearn.metrics import silhouette_score\n",
    "\n",
    "tf.random.set_seed(42)\n",
    "np.random.seed(42)\n",
    "\n",
    "# ── 1. Build the Autoencoder ─────────────────────────────────────────────────\n",
    "# X_scaled is your 14-feature StandardScaler output from earlier\n",
    "input_dim    = X_scaled.shape[1]   # 14\n",
    "encoding_dim = 3                   # bottleneck — same idea as PCA n_components\n",
    "\n",
    "inputs  = keras.Input(shape=(input_dim,))\n",
    "\n",
    "# Encoder: 14 → 8 → 3\n",
    "encoded = layers.Dense(8,            activation='relu')(inputs)\n",
    "encoded = layers.Dense(encoding_dim, activation='relu', name='bottleneck')(encoded)\n",
    "\n",
    "# Decoder: 3 → 8 → 14\n",
    "decoded = layers.Dense(8,         activation='relu')(encoded)\n",
    "decoded = layers.Dense(input_dim, activation='linear')(decoded)\n",
    "\n",
    "autoencoder = keras.Model(inputs, decoded, name='autoencoder')\n",
    "encoder     = keras.Model(inputs, encoded, name='encoder')\n",
    "\n",
    "autoencoder.compile(optimizer='adam', loss='mse')\n",
    "autoencoder.summary()"
   ]
